# ── Core ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./scanner.db
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000          # Public API URL used in email links
# Set to "production" in prod to disable the automatic localhost CORS origins
ENV=
# CORS origins (comma-separated). localhost:3000 is added automatically when ENV != production
CORS_ORIGINS=https://nullscan.io,https://www.nullscan.io

# ── Email (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Nullscan <noreply@nullscan.io>

# ── LLM / Strix ─────────────────────────────────────────────────────────
STRIX_PATH=strix
# API key passed to Strix's LLM (LiteLLM). Provider depends on the model strings below.
LLM_API_KEY=sk-xxxxx
# OpenAI key used by the report processor (structured-output extraction)
OPENAI_API_KEY=sk-xxxxx

# Per-tier scan configuration (field names must match app/config.py Settings)
# Model strings are LiteLLM-style: "openai/gpt-5.2", "anthropic/claude-...", "deepseek/...", etc.
TIER_QUICK_LLM=openai/gpt-5.2
TIER_QUICK_ITERATIONS=50
TIER_QUICK_MODE=quick
TIER_PRO_LLM=openai/gpt-5.2
TIER_PRO_ITERATIONS=300
TIER_PRO_MODE=standard
TIER_DEEP_LLM=openai/gpt-5.2
TIER_DEEP_ITERATIONS=500
TIER_DEEP_MODE=deep

# Per-tier cost limits (USD) — scan is told to wrap up once exceeded
TIER_QUICK_COST_LIMIT=4.0
TIER_PRO_COST_LIMIT=150.0
TIER_DEEP_COST_LIMIT=600.0

# Per-tier concurrent-agent cap and sub-agent wait timeout (seconds)
TIER_QUICK_MAX_AGENTS=15
TIER_QUICK_WAIT_TIMEOUT=120
TIER_PRO_MAX_AGENTS=25
TIER_PRO_WAIT_TIMEOUT=300
TIER_DEEP_MAX_AGENTS=40
TIER_DEEP_WAIT_TIMEOUT=600

# ── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── Admin / misc ────────────────────────────────────────────────────────
# Protects /scans/admin/* endpoints
ADMIN_API_KEY=
# Comma-separated emails that bypass the free-scan rate limit
UNLIMITED_EMAILS=
